SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Direct database connection string (for SQLAlchemy)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.yhgmxkpfkmguywjgzdid.supabase.co:5432/postgres

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_MAX_RPM=15                 # Free tier rate limit (requests per minute)

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the entire JSON content as a single-line string (or path to file)
FIREBASE_CREDENTIALS_JSON=credentials/firebase.json

# Alternatively, use path to JSON file:
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── Upstash Redis (Cache) ──────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://clear-kiwi-108185.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAAaaZAAIgcDJlZjU2Mzc0MjQ2ODk0N2M4YmNmNDllMzgxOWUzOTdhYw

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
DAILY_BRIEF_HOUR=10               # Hour (24h) to fetch news and send notifications
DAILY_BRIEF_MINUTE=0              # Minute to trigger
CLEANUP_DAYS_OLD=30               # Delete articles older than N days

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE_AUTHENTICATED=100
RATE_LIMIT_PER_MINUTE_ANONYMOUS=20

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-frontend.com

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── News Fetching ──────────────────────────────────────────────────────────────
FETCH_TIMEOUT_SECONDS=30
FETCH_MAX_RETRIES=3
FETCH_RETRY_DELAY_SECONDS=2
MAX_ARTICLES_PER_SOURCE=50        # Cap articles fetched per source per run
MIN_TRUST_SCORE=40                # Reject articles below this trust score
MIN_FINAL_SCORE=30                # Reject articles below this final ranking score
MIN_BRIEF_ARTICLES=10             # Minimum articles in a daily brief

# ── Duplicate Detection ────────────────────────────────────────────────────────
SEMANTIC_SIMILARITY_THRESHOLD=0.92  # Cosine similarity threshold for duplicates

# ── Cache TTLs (seconds) ───────────────────────────────────────────────────────
CACHE_TTL_NEWS_LATEST=300         # 5 minutes
CACHE_TTL_NEWS_DETAIL=1800        # 30 minutes
CACHE_TTL_CATEGORIES=3600         # 1 hour
CACHE_TTL_BRIEF=43200             # 12 hours (until next brief)

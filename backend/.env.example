# ── Supabase (Cloud PostgreSQL + Auth) ─────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://yhgmxkpfkmguywjgzdid.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InloZ214a3Bma21ndXl3amd6ZGlkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxNTc0MjQsImV4cCI6MjA5ODczMzQyNH0.9kgC8vMIfL2kAqc21_hyMC-NJqydGtr1V9MQwBwRGWA
